@{
    ViewData["Title"] = "BlockoHolics | Arduino-Powered High-Tech Stacking";
}

<!-- 
    BlockoHolics Landing Page - Razor View (.cshtml)
    Theme: CyberCircuit Industrial (Dark Mode)
    Primary Color: #00979C (Arduino Blue)
    Accent Color: #FD8B00 (Electric Orange)
-->

<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --arduino-blue: #00979C;
        --electric-orange: #FD8B00;
        --industrial-bg: #0c0f0f;
    }

    body {
        background-color: var(--industrial-bg);
        color: #edeeed;
        font-family: 'Space Grotesk', sans-serif;
        margin: 0;
        overflow-x: hidden;
    }

    /* Scroll-Driven Animation Utilities */
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease-out;
    }

    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }

    /* Glassmorphism Effect */
    .glass-panel {
        background: rgba(23, 26, 26, 0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(127, 238, 243, 0.1);
        border-radius: 8px;
    }

    /* Hero Glow */
    .glow-text {
        text-shadow: 0 0 20px rgba(0, 151, 156, 0.6);
    }
</style>

