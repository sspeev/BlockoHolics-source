@using BlockoHolicsWeb.Data.Models;
@using System.Linq

@model IEnumerable<PlayerModel>
@{
    ViewData["Title"] = "BlockoHolics | Arduino-Powered High-Tech Stacking";
    var topPlayers = (Model ?? Enumerable
        .Empty<PlayerModel>())
        .Where(p => p.IsFinished)
        .Take(3)
        .ToList();
}
<div class="min-h-screen flex flex-col">
    <!-- Hero Section -->
    <section class="min-h-screen relative pt-32 pb-20 px-8 flex flex-col items-center text-center">
        <div class="absolute inset-0 -z-10 opacity-20" style="background-image: url('{{DATA:IMAGE:IMAGE_6}}'); background-size: cover; background-position: center;"></div>

        <h3 class="uppercase tracking-[0.3em] text-sm text-[var(--arduino-blue)] mb-4 font-bold">Arduino Powered Hardware Experience</h3>
        <h1 class="text-7xl md:text-9xl font-black tracking-tighter glow-text mb-6">BLOCKO<span class="text-[var(--arduino-blue)]">HOLICS</span></h1>
        <p class="max-w-2xl text-lg text-gray-400 mb-10 leading-relaxed">
            The ultimate industrial-scale stacking challenge. Engineered for precision, built for performance.
            32 columns of high-speed technical intensity.
        </p>

        <div class="flex gap-4">
            <a asp-action="Play" class="bg-[var(--arduino-blue)] text-black px-8 py-4 font-bold uppercase tracking-widest hover:bg-white transition-colors duration-300 inline-block">
                Start Stacking
            </a>
            
        </div>
    </section>

    <!-- Tech Specs Grid -->
    <section class="px-8 py-20 bg-black/40">
        <div class="max-w-7xl mx-auto">
            <h2 class="text-3xl font-bold uppercase tracking-tighter mb-16">Technical <span class="text-[var(--arduino-blue)]">Specifications</span></h2>

            <div class="flex flex-row gap-5">
                <div class="p-8 border-l-2 border-[var(--arduino-blue)]/30 reveal">
                    <div class="text-[var(--arduino-blue)] mb-6">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                    </div>
                    <h4 class="font-bold uppercase tracking-widest mb-4">32-Column Grid</h4>
                    <p class="text-sm text-gray-500 leading-relaxed">Massive visual playground across 4 MAX7219 matrices. High-density pixel tracking.</p>
                </div>

                <div class="p-8 border-l-2 border-[var(--arduino-blue)]/30 reveal" style="transition-delay: 0.1s">
                    <div class="text-[var(--arduino-blue)] mb-6">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    </div>
                    <h4 class="font-bold uppercase tracking-widest mb-4">Difficulty Scaling</h4>
                    <p class="text-sm text-gray-500 leading-relaxed">Adaptive speed algorithms. The higher you stack, the faster it goes.</p>
                </div>

                <div class="p-8 border-l-2 border-[var(--arduino-blue)]/30 reveal" style="transition-delay: 0.3s">
                    <div class="text-[var(--arduino-blue)] mb-6">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" /></svg>
                    </div>
                    <h4 class="font-bold uppercase tracking-widest mb-4">Single-Key Input</h4>
                    <p class="text-sm text-gray-500 leading-relaxed">Zero-latency push-button interface. Pure mechanical feedback for satisfaction.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Architecture Section -->
    <section class="px-8 py-32 max-w-7xl mx-auto w-full">
        <div class="text-center mb-20 reveal">
            <h2 class="text-4xl font-black uppercase tracking-tighter mb-4">Tech <span class="text-[var(--arduino-blue)]">Stack</span></h2>
        </div>

        <div class="glass-panel overflow-hidden reveal">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/5 text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400">
                        <th class="px-8 py-6">Layer</th>
                        <th class="px-8 py-6">Technology</th>
                        <th class="px-8 py-6">Sources</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                        <td class="px-8 py-6 font-bold text-[var(--arduino-blue)]">Hardware</td>
                        <td class="px-8 py-6 font-bold">C++ | Arduino syntax</td>
                        <td class="px-8 py-6 text-grey-500">Github Copilot, Sunfounder.com</td>
                    </tr>
                    <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                        <td class="px-8 py-6 font-bold text-[var(--arduino-blue)]">Database</td>
                        <td class="px-8 py-6 font-bold">Entity Framework 10 | Docker</td>
                        <td class="px-8 py-6 text-grey-500">Github Copilot</td>
                    </tr>
                    <tr class="border-b border-white/5 hover:bg-white/[0.02] transition-colors">
                        <td class="px-8 py-6 font-bold text-[var(--arduino-blue)]">Back-end</td>
                        <td class="px-8 py-6 font-bold">ASP.NET 10</td>
                        <td class="px-8 py-6 text-grey-500">Github Copilot</td>
                    </tr>
                    <tr class="hover:bg-white/[0.02] transition-colors">
                        <td class="px-8 py-6 font-bold text-[var(--arduino-blue)]">Front-end</td>
                        <td class="px-8 py-6 font-bold">cshtml and razor pages</td>
                        <td class="px-8 py-6 text-grey-500">Stitch AI, Google AI Studio</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- Leaderboard / Hall of Fame -->
    <section class="px-8 py-32 bg-black/60 relative overflow-hidden">
        <div class="absolute right-0 bottom-0 text-[15rem] font-black text-white/[0.02] leading-none select-none">STACK</div>

        <div class="max-w-4xl mx-auto relative z-10">
            <div class="flex items-end justify-between mb-16 reveal">
                <div>
                    <div class="flex items-center gap-4 mb-2">
                        <div class="w-12 h-1 bg-[var(--electric-orange)]"></div>
                        <h2 class="text-3xl font-black uppercase tracking-tighter">Top 3 <span class="text-[var(--arduino-blue)]">players</span></h2>
                    </div>
                </div>
                <div class="hidden md:flex gap-1 items-end">
                    <div class="w-4 bg-white/50 h-8"></div>
                    <div class="w-4 bg-[var(--arduino-blue)] h-16"></div>
                    <div class="w-4 bg-[var(--arduino-blue)] h-24"></div>
                    <div class="w-4 bg-white/20 h-12"></div>
                </div>
            </div>

            <div class="space-y-4">
                <!-- Leaderboard Row -->
                @for (var i = 0; i < topPlayers.Count; i++)
                {
                    var player = topPlayers[i];
                    var rank = (i + 1).ToString("D2");
                    var borderClass = i == 0 ? "border-[var(--arduino-blue)]" : "border-white/5";

                    <div class="glass-panel p-6 flex items-center justify-between border-l-4 @borderClass reveal" style="transition-delay: @(0.1 * (i + 1))s">
                        <div class="flex items-center gap-8">
                            <span class="text-2xl font-black italic opacity-20">@rank</span>
                            <div>
                                <div class="font-bold tracking-widest uppercase">@player.Name</div>
                            </div>
                        </div>
                        <div class="text-right">
                            <div class="text-2xl font-black text-[var(--arduino-blue)]">@player.Time</div>
                        </div>
                    </div>
                }
            </div>

            <a href="/Home/Leaderboard" class="w-full mt-12 py-6 border border-white/10 text-xs uppercase font-bold tracking-[0.4em] hover:bg-white hover:text-black transition-all duration-300 inline-block text-center">
                Enter Competition Protocol →
            </a>
        </div>
    </section>
</div>

<script>
    // Simple intersection observer for scroll-driven reveals
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.15 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
