
@model IEnumerable<Blockoholics.Models.Player>
@{
    ViewData["Title"] = "Blockoholics Leaderboard";
    Layout = null; // This view includes its own HTML head/styles; set to null to render standalone
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;900&family=Space+Grotesk:wght@300;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-cyan: #00f2ff;
            --neon-orange: #ff8c00;
            --cyber-bg: #0a0b10;
        }

        body {
            background-color: var(--cyber-bg);
            background-image: url('https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&q=80&w=2048');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            font-family: 'Inter', sans-serif;
            color: white;
            margin: 0;
        }

        .radial-overlay {
            background-image: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.8) 100%);
        }

        .glow-cyan {
            box-shadow: 0 0 10px rgba(0, 242, 255, 0.3), inset 0 0 5px rgba(0, 242, 255, 0.2);
            border: 1px solid rgba(0, 242, 255, 0.5);
        }

        .glow-orange {
            box-shadow: 0 0 15px rgba(255, 140, 0, 0.4), inset 0 0 8px rgba(255, 140, 0, 0.2);
            border: 1px solid rgba(255, 140, 0, 0.6);
        }

        .text-glow-cyan {
            text-shadow: 0 0 8px rgba(0, 242, 255, 0.6);
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1rem;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(0, 242, 255, 0.3);
            border-radius: 10px;
        }

        @@keyframes scroll-indicator {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(300%); }
        }

        .animate-scroll-indicator {
            animation: scroll-indicator 4s ease-in-out infinite;
        }

        .font-display {
            font-family: 'Space Grotesk', sans-serif;
        }
    </style>
</head>
<body>
    <div class="relative min-h-screen flex flex-col items-center justify-center p-4 md:p-8 overflow-hidden">
        <!-- Background Image Overlay -->
        <div class="fixed inset-0 bg-black/70 pointer-events-none z-[-1] radial-overlay"></div>

        <!-- Back to Home Button -->
        <a href="/" class="absolute top-8 left-8 flex items-center gap-2 px-4 py-2 rounded-lg border border-neon-cyan text-neon-cyan font-bold uppercase tracking-wider text-sm glow-cyan hover:bg-neon-cyan/10 transition-all cursor-pointer no-underline">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Back to Home
        </a>

        <!-- Header -->
        <div class="text-center mb-12">
            <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white font-display">
                <span class="text-neon-cyan text-glow-cyan">Blockoholics</span>
                <br />
                Leaderboard
            </h1>
        </div>

        <!-- Leaderboard Container -->
        <div class="w-full max-w-4xl glass-panel p-6 md:p-10 relative">
            <!-- Table Header -->
            <div class="grid grid-cols-3 mb-6 px-4 text-xs md:text-sm font-bold uppercase tracking-[0.2em] text-neon-cyan opacity-80">
                <div class="text-left">Rank</div>
                <div class="text-center">Player Name</div>
                <div class="text-right">Best Time</div>
            </div>

            <!-- Player List -->
            <div class="space-y-3 max-h-[50vh] overflow-y-auto pr-2 custom-scrollbar">
                @if (Model != null)
                {
                    @foreach (var player in Model)
                    {
                        var isTop3 = player.Rank <= 3;
                        <div class="grid grid-cols-3 items-center px-6 py-4 rounded-xl transition-all @(isTop3 ? "glow-orange bg-neon-orange/5" : "glow-cyan bg-neon-cyan/5")">
                            <div class="text-lg md:text-xl font-black @(isTop3 ? "text-neon-orange" : "text-white")">
                                @player.Rank
                            </div>
                            <div class="text-center font-medium text-sm md:text-base tracking-wide">
                                @player.Name
                            </div>
                            <div class="text-right font-mono text-sm md:text-base @(isTop3 ? "text-neon-orange" : "text-white/80")">
                                @player.Time
                            </div>
                        </div>
                    }
                }
                else
                {
                    <!-- Fallback Static Data for Preview/Demo -->
                    <div class="grid grid-cols-3 items-center px-6 py-4 rounded-xl transition-all glow-orange bg-neon-orange/5">
                        <div class="text-lg md:text-xl font-black text-neon-orange">1</div>
                        <div class="text-center font-medium text-sm md:text-base tracking-wide">CircuitMaster_X</div>
                        <div class="text-right font-mono text-sm md:text-base text-neon-orange">00:45.32</div>
                    </div>
                    <div class="grid grid-cols-3 items-center px-6 py-4 rounded-xl transition-all glow-cyan bg-neon-cyan/5">
                        <div class="text-lg md:text-xl font-black text-white">2</div>
                        <div class="text-center font-medium text-sm md:text-base tracking-wide">ByteRunner</div>
                        <div class="text-right font-mono text-sm md:text-base text-white/80">00:48.10</div>
                    </div>
                }
            </div>

            <!-- Decorative Scrollbar Indicator -->
            <div class="absolute right-4 top-24 bottom-10 w-1 bg-white/5 rounded-full overflow-hidden">
                <div class="w-full h-1/4 bg-neon-cyan shadow-[0_0_10px_#00f2ff] animate-scroll-indicator"></div>
            </div>
        </div>

        <!-- Background Decorative Elements -->
        <div class="fixed inset-0 pointer-events-none z-[-1]">
            <div class="absolute top-1/4 -left-20 w-64 h-64 bg-neon-cyan/10 blur-[100px] rounded-full"></div>
            <div class="absolute bottom-1/4 -right-20 w-64 h-64 bg-neon-orange/10 blur-[100px] rounded-full"></div>
        </div>
    </div>
</body>
</html>
