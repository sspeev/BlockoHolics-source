@using BlockoHolicsWeb.Models;

@model IList<PlayerModel>
@{
}

<section class="leaderboard-page relative min-h-screen p-4 md:p-8 overflow-hidden">
    <!-- Single background blur overlay -->
    <div class="absolute inset-0 pointer-events-none z-0 radial-overlay"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen">
        <!-- Back to Home Button -->
        <a href="/" class="absolute top-8 left-8 flex items-center gap-2 px-4 py-2 rounded-lg border border-neon-cyan text-neon-cyan font-bold uppercase tracking-wider text-sm glow-cyan hover:bg-neon-cyan/10 transition-all cursor-pointer no-underline">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
            Back to Home
        </a>

        <!-- Header -->
        <div class="text-center mb-12">
            <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white font-display">
                <span class="text-neon-cyan text-glow-cyan">Blockoholics</span>
                <br />
                Leaderboard
            </h1>
        </div>

        <!-- Leaderboard Container -->
        <div class="w-full max-w-4xl glass-panel p-6 md:p-10 relative">
            <!-- Table Header -->
            <div class="leaderboard-grid mb-4 px-4 text-xs md:text-sm font-bold uppercase tracking-[0.2em] text-neon-cyan opacity-80">
                <div class="text-left">Rank</div>
                <div class="text-left">Player Name</div>
                <div class="text-right">Best Time</div>
                <div class="text-right">Has Finished</div>
            </div>

            <!-- Player List -->
            <div class="space-y-3 max-h-[50vh] overflow-y-auto pr-2 custom-scrollbar">
                @if (Model != null)
                {
                    @foreach (var player in Model)
                    {
                        var isTop3 = player.Rank <= 3;
                        <div class="leaderboard-grid px-6 py-4 rounded-xl transition-all @(isTop3 ? "glow-orange bg-neon-orange/5" : "glow-cyan bg-neon-cyan/5")">
                            <div class="text-lg md:text-xl font-black @(isTop3 ? "text-neon-orange" : "text-white")">@player.Rank</div>
                            <div class="text-sm md:text-base tracking-wide truncate">@player.Name</div>
                            <div class="text-right font-mono text-sm md:text-base @(isTop3 ? "text-neon-orange" : "text-white/80")">@player.Time</div>
                            <div class="text-right text-sm md:text-base @(player.IsFinished ? "text-neon-cyan" : "text-white/70")">
                                @(player.IsFinished ? "Finished" : "Not Finished")
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Decorative Scrollbar Indicator -->
            <div class="absolute right-4 top-24 bottom-10 w-1 bg-white/5 rounded-full overflow-hidden">
                <div class="w-full h-1/4 bg-neon-cyan shadow-[0_0_10px_#00f2ff] animate-scroll-indicator"></div>
            </div>
        </div>
    </div>
</section>