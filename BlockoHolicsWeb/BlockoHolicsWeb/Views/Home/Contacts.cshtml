@{
    ViewData["Title"] = "Contact | BlockoHolics";
}

<section class="contacts-page min-h-screen px-6 py-16 md:px-10">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-14">
            <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tight">
                GitHub <span class="text-[var(--arduino-blue)]">Contributors</span>
            </h1>
            <p class="mt-4 text-gray-400 tracking-wide">
                Replace placeholders with your real GitHub accounts.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
            <article class="profile-card p-6">
                <img class="avatar mb-4" src="https://github.com/sspeev.png" alt="Stoyan Peev" />
                <h2 class="text-xl font-bold tracking-wide">Stoyan Peev</h2>
                <p class="text-sm text-gray-400 mb-5">Developer</p>
                <a class="profile-link" href="https://github.com/sspeev" target="_blank" rel="noopener noreferrer">View github/sspeev</a>
            </article>

            <article class="profile-card p-6">
                <img class="avatar mb-4" src="https://github.com/1Yanis1.png" alt="Yanis Homkov" />
                <h2 class="text-xl font-bold tracking-wide">Yanis Homkov</h2>
                <p class="text-sm text-gray-400 mb-5">UI/UX Designer</p>
                <a class="profile-link" href="https://github.com/1Yanis1" target="_blank" rel="noopener noreferrer">View gitHub/1Yanis1</a>
            </article>

            <article class="profile-card p-6">
                <img class="avatar mb-4" src="https://github.com/Vd1mitrov.png" alt="Viktor Dimitrov" />
                <h2 class="text-xl font-bold tracking-wide">Viktor Dimitrov</h2>
                <p class="text-sm text-gray-400 mb-5">Merchant</p>
                <a class="profile-link" href="https://github.com/Vd1mitrov" target="_blank" rel="noopener noreferrer">View gitHub/Vd1mitrov</a>
            </article>

            <article class="profile-card p-6">
                <img class="avatar mb-4" src="https://github.com/Bob4ou.png" alt="Boris Georgiev" />
                <h2 class="text-xl font-bold tracking-wide">Boris Georgiev</h2>
                <p class="text-sm text-gray-400 mb-5">Product Manager</p>
                <a class="profile-link" href="https://github.com/Bob4ou" target="_blank" rel="noopener noreferrer">View gitHub/Bob4ou</a>
            </article>
        </div>
    </div>
</section>
