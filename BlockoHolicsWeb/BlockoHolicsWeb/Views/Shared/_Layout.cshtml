<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlockoHolicsWeb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;900&family=Space+Grotesk:wght@300;700&display=swap" rel="stylesheet">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BlockoHolicsWeb.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    
    <div class="container flex-fill">
        <main role="main" class="h-100 py-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-auto px-8 py-12 border-t border-white/5 bg-black">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
            <div class="text-[var(--arduino-blue)] font-black text-xl tracking-tighter">BLOCKOHOLICS LABORATORY</div>
            <div class="text-[10px] text-gray-500 uppercase tracking-widest">&copy; 2026 BlockoHolics Laboratory. All Rights Reserved.</div>
            <div class="flex gap-8 text-[10px] uppercase font-bold tracking-widest text-gray-400">
                <a asp-controller="Home" asp-action="Privacy" class="hover:text-[var(--arduino-blue)] transition-colors">Privacy</a>
                <a asp-controller="Home" asp-action="Contacts" class="hover:text-[var(--arduino-blue)] transition-colors">Contact</a>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
